{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowdyn.github.io/terafab-decision-twin/schema/scenario_schema.json",
  "title": "Terafab Decision Twin Scenario Schema v0.3.0",
  "type": "object",
  "required": [
    "metadata",
    "time",
    "terafab_phase",
    "energy",
    "cooling",
    "water",
    "manufacturing",
    "economics",
    "governance",
    "policy",
    "control"
  ],
  "$defs": {
    "status": {
      "enum": [
        "verified_project_fact",
        "model_identity",
        "filed_claimed",
        "reported",
        "user_provided",
        "scenario_assumption",
        "stress_test_assumption",
        "unknown",
        "confidential_private_input",
        "derived_output"
      ]
    },
    "confidence": {
      "enum": [
        "locked",
        "high",
        "medium",
        "low",
        "declared",
        "unknown",
        "restricted"
      ]
    },
    "input": {
      "type": "object",
      "required": [
        "value",
        "unit",
        "status",
        "source_ref",
        "confidence",
        "notes"
      ],
      "properties": {
        "value": {},
        "unit": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "source_ref": {
          "type": "string"
        },
        "confidence": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "scenario_id",
        "title",
        "version",
        "scenario_author",
        "scenario_date",
        "model_version",
        "source_bundle_version",
        "scenario_purpose",
        "scenario_type"
      ],
      "properties": {
        "scenario_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "scenario_author": {
          "type": "string"
        },
        "scenario_date": {
          "type": "string"
        },
        "model_version": {
          "type": "string"
        },
        "schema_version": {
          "type": "string"
        },
        "source_bundle_version": {
          "type": "string"
        },
        "scenario_purpose": {
          "type": "string"
        },
        "scenario_type": {
          "enum": [
            "baseline",
            "stress_test",
            "counterfactual",
            "policy",
            "sensitivity",
            "multi_year",
            "demonstration"
          ]
        },
        "calendar_basis": {
          "type": "string"
        },
        "discount_basis": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "time": {
      "type": "object",
      "required": [
        "start_year",
        "end_year",
        "time_step"
      ],
      "properties": {
        "start_year": {
          "type": "integer",
          "minimum": 2026
        },
        "end_year": {
          "type": "integer",
          "minimum": 2026
        },
        "time_step": {
          "enum": [
            "monthly",
            "quarterly",
            "annual"
          ]
        }
      },
      "additionalProperties": true
    },
    "terafab_phase": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/input"
      }
    },
    "energy": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/input"
      }
    },
    "cooling": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/input"
      }
    },
    "water": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/input"
      }
    },
    "manufacturing": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/input"
      }
    },
    "economics": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/input"
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/input"
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/input"
      }
    },
    "control": {
      "type": "object",
      "properties": {
        "strict_evidence": {
          "type": "boolean"
        },
        "fail_on_unverified_claims": {
          "type": "boolean"
        },
        "allow_unknown_substitution": {
          "type": "boolean"
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "enum": [
              "build",
              "delay",
              "scale",
              "redesign",
              "allocate",
              "contract",
              "license",
              "partner",
              "curtail",
              "abandon"
            ]
          }
        },
        "output_registry": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "report_format": {
          "enum": [
            "json",
            "markdown",
            "csv",
            "bundle"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}